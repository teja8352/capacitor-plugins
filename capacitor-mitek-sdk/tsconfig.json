{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "outDir": "./dist/esm/",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "emitDeclarationOnly": true,
    "strict": true,
    "esModuleInterop": true,
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
