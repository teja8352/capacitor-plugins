{
  "name": "capacitor-mitek-sdk",
  "version": "1.0.0",
  "description": "Capacitor plugin for Mitek MiSnap SDK",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    }
  },
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/",
    "capacitor-mitek-sdk.podspec"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "rimraf": "^5.0.10",
    "rollup": "^4.24.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "keywords": [
    "capacitor",
    "plugin",
    "mitek",
    "misnap",
    "identity",
    "document",
    "face",
    "biometric",
    "nfc",
    "kyc"
  ]
}
